{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-6",
  "small_model": "anthropic/claude-haiku-4-5",
  "autoupdate": true,
  "share": "manual",
  "plugin": [
    "@dietrichgebert/ponytail"
  ],
  "provider": {
    "pcg": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "PCG AI Gateway",
      "options": {
        "baseURL": "https://gateway.pcg.io"
      },
      "models": {
        "claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5 (20251001)",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "gemini-3.1-flash-lite": {
          "name": "Gemini 3.1 Flash Lite",
          "limit": {
            "context": 1048576,
            "output": 65536
          }
        },
        "gemma-4-26b": {
          "name": "Gemma 4 26B",
          "limit": {
            "context": 256000,
            "output": 128000
          }
        },
        "Qwen3.6-35B-A3B-FP8": {
          "name": "Qwen 3.6 35B A3B FP8"
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro",
          "limit": {
            "context": 1048576,
            "output": 65535
          }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "limit": {
            "context": 1000000,
            "output": 64000
          }
        },
        "gemini-3.5-flash": {
          "name": "Gemini 3.5 Flash",
          "limit": {
            "context": 1048576,
            "output": 65535
          }
        },
        "gemini-2.5-flash-image": {
          "name": "Gemini 2.5 Flash Image",
          "limit": {
            "context": 32768,
            "output": 32768
          }
        },
        "Kimi-K2.6": {
          "name": "Kimi K2.6"
        },
        "GLM-5.2": {
          "name": "GLM 5.2"
        },
        "claude-sonnet-5": {
          "name": "Claude Sonnet 5",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "pcg-claude-sonnet-4-6-1m": {
          "name": "PCG Claude Sonnet 4.6 1M",
          "limit": {
            "context": 1000000,
            "output": 64000
          }
        },
        "claude-opus-4-8": {
          "name": "Claude Opus 4.8",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "claude-sonnet-4-6-1m": {
          "name": "Claude Sonnet 4.6 1M",
          "limit": {
            "context": 1000000,
            "output": 64000
          }
        },
        "claude-opus-4-8-1m": {
          "name": "Claude Opus 4.8 1M",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        }
      }
    }
  },
  "enabled_providers": [
    "anthropic",
    "github-copilot",
    "pcg"
  ],
  "permission": {
    "edit": {
      "*": "ask",
      "*.py": "allow",
      "*.tf": "allow"
    },
    "bash": {
      "*": "ask",
      "git add *": "allow",
      "git commit *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "cat *": "allow",
      "uv *": "allow",
      "ls *": "allow",
      "find *": "allow",
    }
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "formatter": {
    "jq": {
      "command": [
        "jq",
        "."
      ],
      "extensions": [
        "json"
      ]
    },
    "prettier-yaml": {
      "command": [
        "prettier",
        "--parser",
        "yaml"
      ],
      "extensions": [
        "yaml",
        "yml"
      ]
    }
  },
  "instructions": [],
  "mcp": {
    "excalidraw": {
      "type": "remote",
      "url": "https://mcp.excalidraw.com",
      "enabled": true
    },
    "adk-docs": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "AgentDevelopmentKit:https://adk.dev/llms.txt",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "pydantic-docs": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "PydanticDocs:https://pydantic.dev/llms.txt",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "langfuse-docs": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "LangfuseDocs:https://langfuse.com/llms.txt",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "docker-docs": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "DockerDocs:https://docs.docker.com/llms.txt",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "chainlit-docs": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "ChainlitDocs:https://docs.chainlit.io/llms.txt",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "uv-docs": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "UVDocs:https://docs.astral.sh/uv/llms.txt",
        "--transport",
        "stdio"
      ],
      "enabled": true
    }
  }
}
