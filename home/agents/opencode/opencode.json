{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-6",
  "small_model": "anthropic/claude-haiku-4-5",
  "autoupdate": true,
  "share": "manual",
  "enabled_providers": [
    "anthropic",
    "github-copilot"
  ],
  "permission": {
    "edit": {
      "*": "ask",
      "*.py": "allow",
      "*.tf": "allow"
    },
    "bash": {
      "*": "ask",
      "git add *": "allow",
      "git commit *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "cat *": "allow",
      "uv *": "allow",
    }
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "formatter": {
    "jq": {
      "command": [
        "jq",
        "."
      ],
      "extensions": [
        "json"
      ]
    },
    "prettier-yaml": {
      "command": [
        "prettier",
        "--parser",
        "yaml"
      ],
      "extensions": [
        "yaml",
        "yml"
      ]
    }
  },
  "instructions": [],
  "mcp": {
    "excalidraw": {
      "type": "remote",
      "url": "https://mcp.excalidraw.com",
      "enabled": true
    },
    "adk-docs": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "AgentDevelopmentKit:https://adk.dev/llms.txt",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "pydantic-docs": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "PydanticDocs:https://pydantic.dev/llms.txt",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "langfuse-docs": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "LangfuseDocs:https://langfuse.com/llms.txt",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "docker-docs": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "DockerDocs:https://docs.docker.com/llms.txt",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "chainlit-docs": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "ChainlitDocs:https://docs.chainlit.io/llms.txt",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "uv-docs": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "mcpdoc",
        "mcpdoc",
        "--urls",
        "UVDocs:https://docs.astral.sh/uv/llms.txt",
        "--transport",
        "stdio"
      ],
      "enabled": true
    }
  }
}
